# Optional local overrides for deployment scripts.
# Copy to `configs/deploy.env` to keep private values out of Git.

AUDIO_MONITOR_TARGET=pi@raspberrypi.local
AUDIO_MONITOR_REMOTE_DIR=/opt/audio-monitor

# Optional password-based SSH auth from a local secret store.
# Example for macOS Keychain:
# AUDIO_MONITOR_SSH_PASSWORD_SECRET_CMD='security find-generic-password -a pi -s audio-monitor-rpi -w'
#
# Plain env fallback is supported too, but a secret command is preferred:
# AUDIO_MONITOR_SSH_PASSWORD=super-secret
